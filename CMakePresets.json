{
  "version": 6,
  "configurePresets": [
    {
      "name": "msvc-base",
      "hidden": true,
      "generator": "Visual Studio 18 2026",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "CMAKE_CXX_EXTENSIONS": "OFF",
        "BUILD_SAMPLES": "ON",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "msvc-debug",
      "displayName": "MSVC Debug",
      "description": "MSVC build with debug symbols",
      "inherits": "msvc-base",
      "cacheVariables": {
        "BUILD_TESTS": "ON"
      }
    },
    {
      "name": "msvc-release",
      "displayName": "MSVC Release",
      "description": "MSVC build with full optimizations (/O2)",
      "inherits": "msvc-base",
      "cacheVariables": {
        "BUILD_TESTS": "OFF"
      }
    },

    {
      "name": "gcc-base",
      "hidden": true,
      "description": "Base configuration for MinGW GCC",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "CMAKE_CXX_EXTENSIONS": "OFF",
        "BUILD_SAMPLES": "ON",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      },
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "environment": {
        "CC": "gcc",
        "CXX": "g++"
      }
    },
    {
      "name": "gcc-debug",
      "displayName": "GCC Debug",
      "description": "GCC build with debug symbols (-g)",
      "inherits": "gcc-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTS": "ON"
      }
    },
    {
      "name": "gcc-release",
      "displayName": "GCC Release",
      "description": "GCC build with optimizations (-O3)",
      "inherits": "gcc-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTS": "OFF"
      }
    }
  ],

  "buildPresets": [
    {
      "name": "msvc-debug",
      "configurePreset": "msvc-debug",
      "configuration": "Debug",
      "displayName": "Build MSVC Debug"
    },
    {
      "name": "msvc-release",
      "configurePreset": "msvc-release",
      "configuration": "Release",
      "displayName": "Build MSVC Release"
    },

    {
      "name": "gcc-debug",
      "configurePreset": "gcc-debug",
      "displayName": "Build GCC Debug"
    },
    {
      "name": "gcc-release",
      "configurePreset": "gcc-release",
      "displayName": "Build GCC Release"
    }
  ],

  "testPresets": [
    {
      "name": "msvc-debug",
      "configurePreset": "msvc-debug",
      "configuration": "Debug",
      "displayName": "Test MSVC Debug"
    },

    {
      "name": "gcc-debug",
      "configurePreset": "gcc-debug",
      "configuration": "Debug",
      "displayName": "Test GCC Debug"
    }
  ]
}