// core/error_codes.def

// This file defines error codes and 
// their corresponding messages for the interpreter.

// Lexer
ERROR(unexpected_character,         "Unexpected character")
ERROR(unterminated_string,          "Unterminated string literal")

// Parser
ERROR(expected_expression,          "Expected expression")
ERROR(expected_semicolon,           "Expected ';'")
ERROR(expected_identifier,          "Expected identifier")
ERROR(expected_type,                "Expected type")
ERROR(expected_right_paren,         "Expected ')'")
ERROR(expected_right_brace,         "Expected '}'")
ERROR(expected_left_brace,          "Expected '{'")
ERROR(expected_left_paren_while,    "Expected '(' after 'while'")
ERROR(expected_left_paren_for,      "Expected '(' after 'for'")
ERROR(expected_left_paren_if,       "Expected '(' after 'if'")
ERROR(expected_right_paren_condition, "Expected ')' after condition")
ERROR(unknown_type,                 "Unknown type")
ERROR(void_variable,                "Variables cannot be of type void")
ERROR(invalid_assignment_target,    "Invalid assignment target")

// Type checker
ERROR(type_mismatch_initialization, "Type mismatch in initialization of '{}'")
ERROR(type_mismatch_assignment,     "Type mismatch in assignment")
ERROR(arithmetic_requires_numeric,  "Arithmetic requires numeric operands")
ERROR(comparison_requires_numeric,  "Comparison requires numeric operands")
ERROR(compound_requires_numeric,    "Compound assignment requires numeric operands")
ERROR(compound_requires_lvalue,     "Compound assignment requires variable")
ERROR(logical_requires_bool,        "Logical operators require boolean operands")
ERROR(unary_minus_requires_numeric, "Unary minus requires numeric operand")
ERROR(increment_requires_numeric,   "Increment/decrement requires numeric operand")
ERROR(increment_requires_lvalue,    "Increment/decrement requires variable")
ERROR(not_requires_bool,            "Logical NOT requires boolean operand")
ERROR(condition_not_bool,           "{} condition must be a boolean expression")
ERROR(undefined_variable,           "Undefined variable '{}'")
ERROR(undefined_function,           "Undefined function '{}'")
ERROR(not_a_function,               "'{}' is not a function")
ERROR(no_matching_overload,         "No matching overload for function '{}' with given argument types")
ERROR(argument_count_mismatch,      "Function '{}' expects {} arguments, got {}")
ERROR(argument_type_mismatch,       "Argument {} type mismatch in call to '{}'")
ERROR(redeclaration_variable,       "Redeclaration of variable '{}'")
ERROR(redeclaration_function,       "Redeclaration of function '{}'")
ERROR(return_outside_function,      "Return statement outside of function")
ERROR(return_type_mismatch,         "Return type mismatch")
ERROR(return_missing_value,         "Return with no value in non-void function")
ERROR(unexpected_literal,           "Unexpected literal type")

// Runtime
ERROR(division_by_zero,             "Division by zero")
ERROR(modulo_by_zero,               "Modulo by zero")
ERROR(modulo_requires_int,          "Modulo supported only for integers")
ERROR(unsupported_binary_operator,  "Unsupported binary operator")
ERROR(unsupported_unary_operator,   "Unsupported unary operator")
ERROR(invalid_conversion,           "Invalid type conversion")